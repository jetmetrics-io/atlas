# Ключи сервисного аккаунта static-deploy для Яндекс Object Storage.
# СКОПИРУЙ этот файл в .deploy.env (он в .gitignore, в репозиторий не попадёт)
# и подставь реальные значения. Получить: консоль Яндекс Облака →
# сервисный аккаунт static-deploy → «Создать статический ключ доступа»
# (роль storage.editor достаточно). Старый ключ YCAJEbagGhTFXM6c6moxZy0V6
# засветился в чате — его надо удалить и выпустить новый.

YC_KEY_ID=xxxxxxxxxxxxxxxxxxxx
YC_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
